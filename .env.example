# ─── Questrade API ─────────────────────────────────────────────────────────
# 1. Go to https://apphub.questrade.com → register a personal app
# 2. Generate a manual refresh token from the app page
# 3. Paste it here. The bot will rotate it automatically on each call —
#    your latest token is persisted to .questrade-token.json (gitignored).
# 4. If the token ever expires or the file is lost, generate a new one
#    from apphub.questrade.com and put it back here.
QUESTRADE_REFRESH_TOKEN=

# Practice (sandbox, fake money) vs Live. Start with practice.
# Practice login URL: https://practicelogin.questrade.com/oauth2/authorize
# Live login URL:     https://login.questrade.com/oauth2/authorize
# (api_server is returned by the token endpoint — do not hardcode it)
QUESTRADE_LOGIN_URL=https://practicelogin.questrade.com

# Your Questrade account number (8 digits). Find it in the Questrade web
# portal under Accounts. The bot lists accounts on first run if blank.
QUESTRADE_ACCOUNT_ID=

# ─── Trading config ─────────────────────────────────────────────────────────
# Symbol to trade. Default SPY (SPDR S&P 500 ETF).
SYMBOL=SPY

# Daily timeframe — Golden Cross is a daily-bar strategy.
TIMEFRAME=1D

# Portfolio value — used to calculate position size (1% of portfolio).
PORTFOLIO_VALUE_USD=10000

# Hard cap on a single trade in USD. Bot will never exceed this.
MAX_TRADE_SIZE_USD=500

# Bot stops after this many trades in a calendar day. For Golden Cross
# this is effectively 1 — the strategy doesn't generate many signals.
MAX_TRADES_PER_DAY=1

# Set to "false" to place real orders. Default is paper mode.
# Even with PAPER_TRADING=true, you should still point QUESTRADE_LOGIN_URL
# at the practice environment for the safest possible setup.
PAPER_TRADING=true
